function seedHistory(){
  for(let i=14;i>=0;i--){
    const d=new Date(Date.now()-i*30000);
    const l=d.toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
    S.hPH.push({x:l,y:+(5.2+Math.random()*.6).toFixed(2)});
    S.hEC.push({x:l,y:+(2.2+Math.random()*.9).toFixed(2)});
    S.hWT.push({x:l,y:+(19+Math.random()*3.5).toFixed(1)});
    S.hAT.push({x:l,y:+(22+Math.random()*4).toFixed(1)});
    S.hHM.push({x:l,y:+(68+Math.random()*10).toFixed(0)});
  }
}
