  const push=(a,v)=>{ a.push({x:now,y:v}); if(a.length>20) a.shift(); };
  push(S.hPH,S.s.ph); push(S.hEC,S.s.ec); push(S.hWT,S.s.wt); push(S.hAT,S.s.at); push(S.hHM,S.s.hm);
  if(document.getElementById('page-grafik').classList.contains('on')&&S.chartsInit) updateCharts();
