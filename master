function getChartColors() {
  return document.documentElement.getAttribute('data-theme') === 'dark'
    ? { grid:'rgba(255,255,255,.05)', tick:'#4a5568', tooltip:'#161b24' }
    : { grid:'rgba(0,0,0,.04)', tick:'#94a3b8', tooltip:'#ffffff' };
}

function mkChart(id,arrays,labels,colors){
  const ctx=document.getElementById(id); if(!ctx) return;
  if(S.charts[id]) try{S.charts[id].destroy()}catch(e){}
  const c=getChartColors();
  S.charts[id]=new Chart(ctx,{
    type:'line',
    data:{
      labels:arrays[0].map(d=>d.x),
      datasets:arrays.map((a,i)=>({
        label:labels[i], data:a.map(d=>d.y),
        borderColor:colors[i], backgroundColor:colors[i]+'18',
        fill:i===0, tension:.45, pointRadius:3,
        pointBackgroundColor:colors[i], borderWidth:2,
        pointHoverRadius:5
      }))
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      animation:{duration:400},
      plugins:{
        legend:{display:arrays.length>1,labels:{font:{size:11,family:'Space Mono'},boxWidth:10,color:'#8892a4'}},
        tooltip:{backgroundColor:c.tooltip,titleFont:{family:'Space Mono',size:11},bodyFont:{family:'Space Mono',size:10},cornerRadius:8,borderColor:'rgba(255,255,255,.1)',borderWidth:1,titleColor:'#e8eaf0',bodyColor:'#8892a4'}
      },
      scales:{
        x:{ticks:{font:{size:9,family:'Space Mono'},maxRotation:30,maxTicksLimit:6,color:c.tick},grid:{color:c.grid}},
        y:{ticks:{font:{size:10,family:'Space Mono'},color:c.tick},grid:{color:c.grid}}
      }
    }
  });
}

function renderCharts(){
  if(!S.chartsInit){
    mkChart('cPH',[S.hPH],['pH'],['#00e676']);
    mkChart('cEC',[S.hEC],['EC (mS/cm)'],['#448aff']);
    mkChart('cWT',[S.hWT],['Suhu Air (°C)'],['#ffab00']);
    mkChart('cAir',[S.hAT,S.hHM],['Suhu Udara (°C)','Kelembapan (%)'],['#ff5252','#e040fb']);
    S.chartsInit=true;
  } else { updateCharts(); }
}
function updateCharts(){
  [['cPH',[S.hPH]],['cEC',[S.hEC]],['cWT',[S.hWT]],['cAir',[S.hAT,S.hHM]]].forEach(([id,a])=>{
    const c=S.charts[id]; if(!c) return;
    c.data.labels=a[0].map(d=>d.x);
    a.forEach((arr,i)=>c.data.datasets[i].data=arr.map(d=>d.y));
    c.update('none');
  });
}
