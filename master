/* ══════════════════════════════════════
   SCHEDULE
══════════════════════════════════════ */
function buildSchedule(){
  const now=new Date();
  const months=['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
  document.getElementById('schMonth').textContent=months[now.getMonth()]+' '+now.getFullYear();
  const days=['Min','Sen','Sel','Rab','Kam','Jum','Sab'];
  const todayIdx=now.getDay();
  const sprayDays=[0,1,3,5];
  let html='';
  for(let i=0;i<7;i++){
    const d=new Date(now); d.setDate(now.getDate()-todayIdx+i);
    const isToday=i===todayIdx, isSpray=sprayDays.includes(i);
    html+=`<div class="day-cell${isToday?' today':''}${isSpray?' spray':''}">
      <span class="day-name">${days[i].charAt(0)}</span>
      <div class="day-num">${d.getDate()}</div>
      <div class="day-dot"></div>
    </div>`;
  }
  document.getElementById('dayRow').innerHTML=html;
  let next='Hari ini';
  for(let i=1;i<=7;i++){ const idx=(todayIdx+i)%7; if(sprayDays.includes(idx)){ const nd=new Date(now); nd.setDate(now.getDate()+i); next=days[nd.getDay()]+', '+nd.getDate()+' '+months[nd.getMonth()]; break; } }
  document.getElementById('nextSpray').textContent=next;
}

