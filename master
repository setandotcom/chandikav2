══════════════════════════════════════ */
function trend(cur,prev){ return cur>prev+.05?'↑':cur<prev-.05?'↓':'→'; }
function trendCls(cur,prev){ return cur>prev+.05?'trend-up':cur<prev-.05?'trend-down':'trend-flat'; }

function updateSensorUI() {
  const s=S.s, p=S.prev, t=S.tgt;
  setText('qPH',s.ph.toFixed(2)); setText('qEC',s.ec.toFixed(2));
  setText('qWT',s.wt.toFixed(1)); setText('qAT',s.at.toFixed(1)); setText('qHM',Math.round(s.hm));

  const phSt=s.ph<t.phMin?'bad':s.ph>t.phMax?'warn':'ok';
  const phLbl=s.ph<t.phMin?'ASAM':s.ph>t.phMax?'BASA':'OK';
  setStat('qbPH',phSt,phLbl); setCard('vPH','tPH','bPH','bdPH',s.ph.toFixed(2),s.ph,p.ph,phSt,s.ph<t.phMin?'⚠ Asam':s.ph>t.phMax?'⚠ Basa':'✓ Netral',s.ph/14*100,'var(--accent)');

  const ecSt=s.ec<t.ecMin?'warn':s.ec>t.ecMax?'bad':'ok';
  const ecLbl=s.ec<t.ecMin?'KURANG':s.ec>t.ecMax?'LEBIH':'OK';
  setStat('qbEC',ecSt,ecLbl); setCard('vEC','tEC','bEC','bdEC',s.ec.toFixed(2),s.ec,p.ec,ecSt,s.ec<t.ecMin?'⚠ Kurang':s.ec>t.ecMax?'⚠ Lebih':'✓ Optimal',s.ec/5*100,'var(--blue)');

  const wtSt=s.wt<t.wtMin?'warn':s.wt>t.wtMax?'bad':'ok';
  const wtLbl=s.wt<t.wtMin?'DINGIN':s.wt>t.wtMax?'PANAS':'OK';
  setStat('qbWT',wtSt,wtLbl); setCard('vWT','tWT','bWT','bdWT',s.wt.toFixed(1),s.wt,p.wt,wtSt,s.wt<t.wtMin?'⚠ Dingin':s.wt>t.wtMax?'⚠ Panas':'✓ Normal',(s.wt-10)/25*100,'var(--warn)');

  setText('vAT',s.at.toFixed(1)); setText('vHM',Math.round(s.hm));
  const atSt=s.at>35||s.hm>88?'bad':s.at>30?'warn':'ok';
  setStat('qbAT',atSt,s.at>35?'EKSTREM':s.at>30?'TINGGI':'OK');
  setStat('qbHM','ok','OK');
  const bdAir=document.getElementById('bdAir');
  if(bdAir){ bdAir.textContent=atSt==='bad'?'⚠ Ekstrem':atSt==='warn'?'⚠ Tinggi':'✓ Normal'; bdAir.className=`sc-badge badge-${atSt} mt-8`; }
  setText('heroP',S.relay.pump?'ON':'OFF'); setText('heroF',S.relay.fan?'ON':'OFF');
}

function setCard(valId,trendId,barId,badgeId,dispVal,cur,prev,st,lbl,pct,color){
  setText(valId,dispVal);
  const tr=document.getElementById(trendId);
  if(tr){ tr.textContent=trend(cur,prev); tr.className='sc-trend '+trendCls(cur,prev); }
  const bar=document.getElementById(barId);
  if(bar){ bar.style.width=Math.min(100,Math.max(0,pct))+'%'; bar.style.background=st==='ok'?color:st==='warn'?'var(--warn)':'var(--danger)'; }
  const bd=document.getElementById(badgeId);
  if(bd){ bd.textContent=lbl; bd.className=`sc-badge badge-${st}`; }
}
function setStat(id,st,lbl){ const el=document.getElementById(id); if(!el) return; el.textContent=lbl; el.className=`stat-chip-badge badge-${st}`; }
function setText(id,v){ const e=document.getElementById(id); if(e) e.textContent=v; }

