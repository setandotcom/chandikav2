/* ══════════════════════════════════════
   SENSOR SIMULATION
══════════════════════════════════════ */
function rw(v,mn,mx,st){ return Math.max(mn,Math.min(mx,parseFloat((v+(Math.random()-.5)*st).toFixed(2)))); }

function simulateSensor() {
  const prev={...S.s};
  S.s.ph=rw(S.s.ph,4.5,7.5,.06); S.s.ec=rw(S.s.ec,1.0,4.5,.07);
  S.s.wt=rw(S.s.wt,15,30,.15); S.s.at=rw(S.s.at,18,36,.18); S.s.hm=rw(S.s.hm,50,92,.5);
  S.prev=prev;
  updateSensorUI(); checkAlerts(); pushHistory();
  if(S.fanMode==='auto'){ const should=S.s.at>S.fanThresh; if(should!==S.relay.fan){ S.relay.fan=should; syncRelays(); addNotif('warning','🌀 Kipas Auto',`Suhu ${S.s.at.toFixed(1)}°C ${should?'melebihi':'di bawah'} threshold`,'info'); } }
}

