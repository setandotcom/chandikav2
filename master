document.getElementById('loginPass').addEventListener('keydown', e=>{ if(e.key==='Enter') doLogin() });
document.getElementById('loginUser').addEventListener('keydown', e=>{ if(e.key==='Enter') document.getElementById('loginPass').focus() });

function doLogin() {
  const u = document.getElementById('loginUser').value.trim();
  const p = document.getElementById('loginPass').value;
  const rem = document.getElementById('remMe').checked;
  const btn = document.getElementById('loginBtn');
  const err = document.getElementById('loginErr');
  btn.disabled = true;
  btn.innerHTML = '<div style="width:16px;height:16px;border:2px solid rgba(15,17,23,.3);border-top-color:#0f1117;border-radius:50%;animation:spin .6s linear infinite"></div> Memverifikasi...';
  err.classList.remove('show');
  setTimeout(() => {
    const acct = ACCOUNTS.find(a => a.username.toLowerCase()===u.toLowerCase() && a.password===p);
    if (acct) {
      S.user = acct;
      const sess = JSON.stringify({username:acct.username, role:acct.role});
      rem ? localStorage.setItem('ca2',sess) : sessionStorage.setItem('ca2',sess);
      document.getElementById('loginPage').style.display = 'none';
      startApp(acct);
    } else {
      err.classList.add('show');
      document.getElementById('loginPass').value = '';
      btn.disabled = false;
      btn.innerHTML = '<span>→</span> Masuk ke Dashboard';
      document.querySelector('.login-form-card').style.animation='shake .4s ease';
      setTimeout(()=>document.querySelector('.login-form-card').style.animation='',400);
    }
  }, 800);
}

function doLogout() {
  if(!confirm('Yakin ingin keluar?')) return;
  localStorage.removeItem('ca2'); sessionStorage.removeItem('ca2');
  stopIv(); S.user = null; S.chartsInit = false;
  Object.values(S.charts).forEach(c=>{ try{c.destroy()}catch(e){} });
  S.charts = {};
  document.getElementById('app').classList.remove('on');
  document.getElementById('loginPage').style.display='flex';
  document.getElementById('loginUser').value='';
  document.getElementById('loginPass').value='';
}

function togglePwd() {
