function applyPumpTimer(){ const on=parseInt(document.getElementById('pOn').value)||30; const off=parseInt(document.getElementById('pOff').value)||60; S.pTimer.on=on; S.pTimer.off=off; if(S.pTimer.timeout) clearTimeout(S.pTimer.timeout); function tick(){ S.relay.pump=S.pTimer.phase==='on'; syncRelays(); const nx=S.pTimer.phase==='on'?on:off; S.pTimer.phase=S.pTimer.phase==='on'?'off':'on'; S.pTimer.timeout=setTimeout(tick,nx*1000); } S.pTimer.phase='on'; tick(); updatePumpTxt(); showToast(`⏱ Timer: ON ${on}s / OFF ${off}s`,'ok'); addLog('info',`Timer pompa: ON=${on}s OFF=${off}s`); }
