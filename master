function syncRelays() {
  ['pump','fan'].forEach(k=>{
    const on=S.relay[k];
    const tl=document.getElementById(k==='pump'?'pTL':'fTL');
    const pg=document.getElementById(k==='pump'?'pPill':'fPill');
    const tg=document.getElementById(k==='pump'?'pToggle':'fToggle');
    if(tl){ tl.textContent=on?'ON':'OFF'; tl.style.color=on?'var(--accent)':'var(--text-3)'; }
    if(pg){ pg.className='relay-status '+(on?'rs-on':'rs-off'); pg.innerHTML=`<span class="rs-dot"></span>${on?'ON':'OFF'}`; }
    if(tg) tg.checked=on;
  });
}
function onPump(){ if(S.pumpMode==='auto') return; S.relay.pump=document.getElementById('pToggle').checked; syncRelays(); updatePumpTxt(); const m=S.relay.pump?'ON':'OFF'; showToast('💧 Pompa: '+m,S.relay.pump?'ok':'info'); addNotif('info','💧 Pompa '+m,'Relay pompa diubah manual','relay'); addLog('info','Relay Pompa: '+m); }
function onFan(){  if(S.fanMode==='auto') return; S.relay.fan=document.getElementById('fToggle').checked; syncRelays(); updateFanTxt(); const m=S.relay.fan?'ON':'OFF'; showToast('🌀 Kipas: '+m,S.relay.fan?'ok':'info'); addNotif('info','🌀 Kipas '+m,'Relay kipas diubah manual','relay'); addLog('info','Relay Kipas: '+m); }
function setPumpMode(m){ S.pumpMode=m; document.getElementById('pMM').className='seg-btn'+(m==='manual'?' on':''); document.getElementById('pMA').className='seg-btn'+(m==='auto'?' on':''); document.getElementById('pTimerBox').classList.toggle('hidden',m!=='auto'); if(m==='manual'&&S.pTimer.timeout) clearTimeout(S.pTimer.timeout); updatePumpTxt(); }
function setFanMode(m){ S.fanMode=m; document.getElementById('fMM').className='seg-btn'+(m==='manual'?' on':''); document.getElementById('fMA').className='seg-btn'+(m==='auto'?' on':''); document.getElementById('fAutoBox').classList.toggle('hidden',m!=='auto'); updateFanTxt(); }
