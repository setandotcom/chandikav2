function checkAlerts(){
  const s=S.s,t=S.tgt,now=Date.now();
  if(!(s.ph>=t.phMin&&s.ph<=t.phMax)&&now-S.alertCD.ph>60000){ addNotif('danger','⚠ pH Tidak Normal',`pH: ${s.ph.toFixed(2)} (target ${t.phMin}–${t.phMax})`,'ph'); showToast(`⚠ pH: ${s.ph.toFixed(2)}`,'warn'); S.alertCD.ph=now; }
  if(!(s.ec>=t.ecMin&&s.ec<=t.ecMax)&&now-S.alertCD.ec>60000){ addNotif('warning','⚡ EC Di Luar Range',`EC: ${s.ec.toFixed(2)} mS/cm`,'ec'); showToast(`⚡ EC: ${s.ec.toFixed(2)} mS`,'warn'); S.alertCD.ec=now; }
  if(s.at>35&&now-S.alertCD.t>60000){ addNotif('danger','🌡️ Suhu Ekstrem!',`${s.at.toFixed(1)}°C — cek ventilasi`,'temp'); showToast(`🌡️ Suhu: ${s.at.toFixed(1)}°C`,'err'); S.alertCD.t=now; }
}

