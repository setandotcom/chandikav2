<!DOCTYPE html>

<html lang="id" data-theme="dark">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no"/>
<meta name="mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="theme-color" content="#0f1117"/>
<title>Chandika Agrolestari</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Outfit:wght@300;400;500;600;700;800;900&display=swap');

/* ══════════════════════════════════════
DESIGN TOKENS — INDUSTRIAL PRECISION
══════════════════════════════════════ */
:root {
–accent:       #00e676;
–accent-dim:   #00c853;
–accent-glow:  rgba(0,230,118,.18);
–accent-pale:  rgba(0,230,118,.08);
–warn:         #ffab00;
–warn-pale:    rgba(255,171,0,.1);
–danger:       #ff5252;
–danger-pale:  rgba(255,82,82,.1);
–blue:         #448aff;
–blue-pale:    rgba(68,138,255,.1);
–violet:       #e040fb;
–violet-pale:  rgba(224,64,251,.1);
–teal:         #00bcd4;

–r-xl:   20px;
–r-lg:   14px;
–r-md:   10px;
–r-sm:   7px;
–nav-h:  68px;
–hdr-h:  64px;
–ease:   .25s cubic-bezier(.4,0,.2,1);
–spring: .4s cubic-bezier(.34,1.56,.64,1);

–display: ‘Outfit’, sans-serif;
–mono:    ‘Space Mono’, monospace;
–body:    ‘Outfit’, sans-serif;
}

/* DARK THEME (default) */
[data-theme=“dark”] {
–bg:       #0f1117;
–bg2:      #161b24;
–bg3:      #1e2535;
–card:     #161b24;
–card2:    #1e2535;
–border:   rgba(255,255,255,.07);
–border2:  rgba(255,255,255,.12);
–text:     #e8eaf0;
–text-2:   #8892a4;
–text-3:   #4a5568;
–shadow:   0 4px 24px rgba(0,0,0,.4);
–shadow-sm:0 2px 10px rgba(0,0,0,.3);
–invert:   0;
}

/* LIGHT THEME */
[data-theme=“light”] {
–bg:       #f0f4f8;
–bg2:      #ffffff;
–bg3:      #e8eef5;
–card:     #ffffff;
–card2:    #f0f4f8;
–border:   rgba(0,0,0,.07);
–border2:  rgba(0,0,0,.12);
–text:     #0f1117;
–text-2:   #4a5568;
–text-3:   #94a3b8;
–shadow:   0 4px 24px rgba(0,0,0,.08);
–shadow-sm:0 2px 10px rgba(0,0,0,.06);
–invert:   1;
}

*,*::before,*::after { box-sizing:border-box; margin:0; padding:0 }
html { scroll-behavior:smooth }
body {
font-family: var(–body);
background: var(–bg);
color: var(–text);
min-height: 100dvh;
max-width: 480px;
margin: 0 auto;
overflow-x: hidden;
-webkit-font-smoothing: antialiased;
-webkit-tap-highlight-color: transparent;
transition: background var(–ease), color var(–ease);
}
::-webkit-scrollbar { width:0 }
input, select, button { font-family: var(–body) }

/* ══════════════════════════════════════
SPLASH
══════════════════════════════════════ */
#splash {
position:fixed; inset:0; z-index:900;
background: var(–bg);
display:flex; flex-direction:column; align-items:center; justify-content:center; gap:16px;
transition:opacity .5s ease;
}
#splash.out { opacity:0; pointer-events:none }
.splash-logo {
width:72px; height:72px; border-radius:22px;
background: linear-gradient(135deg, var(–accent), var(–accent-dim));
display:flex; align-items:center; justify-content:center; font-size:36px;
box-shadow: 0 0 40px var(–accent-glow);
animation: splashPulse 1.2s ease infinite alternate;
}
@keyframes splashPulse { from{box-shadow:0 0 20px var(–accent-glow)} to{box-shadow:0 0 60px var(–accent-glow)} }
.splash-brand { font-family:var(–display); font-size:20px; font-weight:800; color:var(–text); letter-spacing:-.3px }
.splash-tag { font-family:var(–mono); font-size:10px; color:var(–accent); letter-spacing:2px; text-transform:uppercase }
.splash-bar { width:48px; height:2px; background:var(–bg3); border-radius:1px; overflow:hidden; margin-top:8px }
.splash-fill { height:100%; background:var(–accent); border-radius:1px; animation:barFlow 1.4s ease infinite }
@keyframes barFlow { 0%{width:0;margin-left:0} 50%{width:60%;margin-left:20%} 100%{width:0;margin-left:100%} }

/* ══════════════════════════════════════
LOGIN
══════════════════════════════════════ */
#loginPage {
position:fixed; inset:0; z-index:800;
display:none; flex-direction:column;
background:var(–bg); overflow:hidden;
}
.login-grid-bg {
position:absolute; inset:0; pointer-events:none; overflow:hidden;
}
.login-grid-bg::before {
content:’’; position:absolute; inset:0;
background-image:
linear-gradient(var(–border) 1px, transparent 1px),
linear-gradient(90deg, var(–border) 1px, transparent 1px);
background-size:32px 32px;
}
.login-grid-bg::after {
content:’’; position:absolute;
top:-40%; left:-20%; width:80%; height:80%;
background: radial-gradient(ellipse, var(–accent-glow) 0%, transparent 70%);
border-radius:50%;
}
.login-top {
flex:1; display:flex; flex-direction:column;
align-items:center; justify-content:center;
padding:40px 24px 24px; position:relative; z-index:1;
}
.login-pill {
display:inline-flex; align-items:center; gap:8px;
border:1px solid var(–border2); border-radius:40px;
padding:7px 14px 7px 10px; margin-bottom:28px;
background:var(–card2); backdrop-filter:blur(12px);
}
.login-pill-dot { width:8px; height:8px; background:var(–accent); border-radius:50%; animation:pulseDot 2s infinite }
.login-pill span { font-family:var(–mono); font-size:11px; color:var(–text-2); letter-spacing:.5px }
.login-headline { font-family:var(–display); font-size:36px; font-weight:900; color:var(–text); text-align:center; line-height:1.05; letter-spacing:-1px; margin-bottom:8px }
.login-headline span { color:var(–accent) }
.login-sub { font-size:14px; color:var(–text-2); text-align:center }
.login-form-card {
background:var(–card); border-top:1px solid var(–border);
border-radius:var(–r-xl) var(–r-xl) 0 0;
padding:28px 24px 40px; position:relative; z-index:1;
}
.form-label { font-family:var(–mono); font-size:10px; font-weight:700; color:var(–text-3); letter-spacing:1.2px; text-transform:uppercase; margin-bottom:8px; display:block }
.form-input-wrap { position:relative; margin-bottom:12px }
.form-input-icon { position:absolute; left:13px; top:50%; transform:translateY(-50%); font-size:15px; pointer-events:none }
.form-input {
width:100%; padding:13px 13px 13px 40px;
background:var(–bg2); border:1.5px solid var(–border);
border-radius:var(–r-md); font-size:15px; font-weight:500;
color:var(–text); outline:none;
transition:border-color var(–ease), background var(–ease), box-shadow var(–ease);
-webkit-appearance:none;
}
.form-input:focus { border-color:var(–accent); background:var(–bg); box-shadow:0 0 0 3px var(–accent-glow) }
.pass-eye { position:absolute; right:13px; top:50%; transform:translateY(-50%); cursor:pointer; font-size:15px; color:var(–text-3) }
.login-row { display:flex; align-items:center; justify-content:space-between; margin:4px 0 18px }
.remember { display:flex; align-items:center; gap:7px; cursor:pointer }
.remember input { accent-color:var(–accent); width:15px; height:15px; cursor:pointer }
.remember span { font-size:13px; color:var(–text-2) }
.forgot { font-size:13px; font-weight:600; color:var(–accent); cursor:pointer }
.login-btn {
width:100%; padding:15px;
background:var(–accent); color:#0f1117;
border:none; border-radius:var(–r-md);
font-family:var(–display); font-size:16px; font-weight:800;
cursor:pointer; letter-spacing:-.2px;
box-shadow:0 4px 24px var(–accent-glow);
transition:transform var(–ease), box-shadow var(–ease), opacity var(–ease);
display:flex; align-items:center; justify-content:center; gap:8px;
}
.login-btn:active { transform:scale(.97) }
.login-btn:disabled { opacity:.5; cursor:not-allowed }
.login-err {
display:none; margin-top:12px;
background:var(–danger-pale); border:1px solid var(–danger);
border-radius:var(–r-md); padding:10px 13px;
font-size:13px; font-weight:500; color:var(–danger); gap:8px; align-items:center;
}
.login-err.show { display:flex }
.login-footer { margin-top:14px; text-align:center; font-family:var(–mono); font-size:10px; color:var(–text-3) }

/* ══════════════════════════════════════
APP SHELL
══════════════════════════════════════ */
#app { display:none }
#app.on { display:block }

/* ══════════════════════════════════════
HEADER
══════════════════════════════════════ */
.hdr {
position:fixed; top:0; left:50%; transform:translateX(-50%);
width:100%; max-width:480px; height:var(–hdr-h);
background:rgba(15,17,23,.85);
backdrop-filter:blur(20px); -webkit-backdrop-filter:blur(20px);
border-bottom:1px solid var(–border);
display:flex; align-items:center; justify-content:space-between;
padding:0 18px; z-index:100;
}
[data-theme=“light”] .hdr { background:rgba(240,244,248,.88) }
.hdr-brand { display:flex; align-items:center; gap:10px }
.hdr-logo { width:34px; height:34px; border-radius:10px; background:var(–accent); display:flex; align-items:center; justify-content:center; font-size:17px; flex-shrink:0 }
.hdr-left {}
.hdr-greet { font-family:var(–display); font-size:15px; font-weight:800; color:var(–text); letter-spacing:-.2px; line-height:1 }
.hdr-sub { font-family:var(–mono); font-size:9px; color:var(–text-3); margin-top:3px; letter-spacing:.3px }
.hdr-right { display:flex; align-items:center; gap:8px }
.hdr-btn {
width:36px; height:36px; background:var(–card2);
border:1px solid var(–border); border-radius:var(–r-md);
cursor:pointer; display:flex; align-items:center; justify-content:center;
font-size:16px; transition:transform var(–ease), border-color var(–ease);
position:relative;
}
.hdr-btn:active { transform:scale(.9) }
.hdr-btn.theme-btn { font-size:14px }
.bell-dot {
position:absolute; top:7px; right:7px;
width:7px; height:7px; background:var(–danger);
border-radius:50%; border:1.5px solid var(–bg);
display:none; animation:pulseDot 2s infinite;
}
.live-pill {
display:flex; align-items:center; gap:5px;
background:var(–accent-pale); border:1px solid rgba(0,230,118,.2);
border-radius:20px; padding:4px 10px;
font-family:var(–mono); font-size:10px; font-weight:700; color:var(–accent);
letter-spacing:.5px;
}
.live-dot { width:6px; height:6px; background:var(–accent); border-radius:50%; animation:pulseDot 2s infinite }
@keyframes pulseDot { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.6;transform:scale(1.4)} }

/* ══════════════════════════════════════
MAIN
══════════════════════════════════════ */
.main {
padding-top:calc(var(–hdr-h) + 14px);
padding-bottom:calc(var(–nav-h) + 14px);
min-height:100dvh;
}
.page { display:none; padding:0 14px; animation:pgIn .3s ease }
.page.on { display:block }
@keyframes pgIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

.sec { font-family:var(–display); font-size:13px; font-weight:700; color:var(–text-2); margin:18px 0 10px 2px; display:flex; align-items:center; justify-content:space-between; text-transform:uppercase; letter-spacing:.8px }
.sec-sub { font-size:11px; font-weight:600; color:var(–accent); cursor:pointer; text-transform:none; letter-spacing:0 }

/* ══════════════════════════════════════
HERO CARD
══════════════════════════════════════ */
.hero-card {
background:var(–card2);
border:1px solid var(–border2);
border-radius:var(–r-xl); padding:20px;
position:relative; overflow:hidden;
box-shadow:var(–shadow);
}
.hero-card-bg {
position:absolute; inset:0; pointer-events:none; overflow:hidden;
}
.hero-card-bg::before {
content:’’; position:absolute; top:-30px; right:-30px;
width:160px; height:160px; border-radius:50%;
background:radial-gradient(circle, var(–accent-glow), transparent 70%);
}
.hero-card-bg::after {
content:‘🥔’; position:absolute; right:14px; top:14px;
font-size:80px; opacity:.06; transform:rotate(-10deg);
}
.hero-top { display:flex; align-items:flex-start; justify-content:space-between; position:relative; z-index:1 }
.hero-tag {
display:inline-flex; align-items:center; gap:5px;
border:1px solid var(–border2); border-radius:20px;
padding:4px 10px; font-family:var(–mono); font-size:10px; color:var(–text-2);
letter-spacing:.4px; margin-bottom:10px; background:var(–bg2);
}
.hero-tag-dot { width:6px; height:6px; background:var(–accent); border-radius:50%; animation:pulseDot 2s infinite }
.hero-title { font-family:var(–display); font-size:26px; font-weight:900; color:var(–text); line-height:1.1; letter-spacing:-.5px }
.hero-date { font-family:var(–mono); font-size:10px; color:var(–text-3); margin-top:6px; letter-spacing:.2px }
.hero-hst {
background:var(–accent); color:#0f1117;
border-radius:var(–r-md); padding:14px 18px; text-align:center;
flex-shrink:0; box-shadow:0 4px 20px var(–accent-glow);
}
.hst-n { font-family:var(–mono); font-size:34px; font-weight:700; line-height:1; display:block }
.hst-l { font-family:var(–mono); font-size:9px; letter-spacing:1.5px; text-transform:uppercase; opacity:.7; display:block; margin-top:2px }
.hero-bottom { display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; margin-top:16px; position:relative; z-index:1 }
.hero-chip {
background:var(–bg2); border:1px solid var(–border);
border-radius:var(–r-md); padding:10px 12px;
display:flex; align-items:center; gap:8px;
}
.hero-chip-icon { font-size:18px }
.hc-label { font-family:var(–mono); font-size:9px; color:var(–text-3); display:block; letter-spacing:.4px; text-transform:uppercase }
.hc-value { font-family:var(–mono); font-size:13px; font-weight:700; color:var(–text); display:block; margin-top:2px }

/* ══════════════════════════════════════
STATS ROW
══════════════════════════════════════ */
.stats-row { display:flex; gap:8px; overflow-x:auto; padding-bottom:4px; margin-bottom:4px }
.stats-row::-webkit-scrollbar { display:none }
.stat-chip {
flex-shrink:0; background:var(–card);
border:1px solid var(–border); border-radius:var(–r-lg); padding:13px 14px;
min-width:104px; position:relative; overflow:hidden;
transition:border-color var(–ease), transform var(–ease);
}
.stat-chip:active { transform:scale(.96) }
.stat-chip-bar { position:absolute; bottom:0; left:0; height:2px; border-radius:0 1px 0 var(–r-lg) }
.sc-ph  .stat-chip-bar { background:var(–accent); width:55% }
.sc-ec  .stat-chip-bar { background:var(–blue); width:70% }
.sc-wt  .stat-chip-bar { background:var(–warn); width:45% }
.sc-at  .stat-chip-bar { background:var(–danger); width:60% }
.sc-hm  .stat-chip-bar { background:var(–violet); width:75% }
.stat-chip-label { font-family:var(–mono); font-size:9px; font-weight:700; color:var(–text-3); text-transform:uppercase; letter-spacing:.7px; margin-bottom:6px }
.stat-chip-val { font-family:var(–mono); font-size:22px; font-weight:700; color:var(–text); line-height:1; display:flex; align-items:baseline; gap:2px }
.stat-chip-unit { font-size:10px; font-weight:400; color:var(–text-3) }
.stat-chip-badge { display:inline-block; margin-top:7px; font-family:var(–mono); font-size:9px; font-weight:700; padding:2px 7px; border-radius:4px; text-transform:uppercase; letter-spacing:.4px }
.badge-ok   { background:var(–accent-pale); color:var(–accent); border:1px solid rgba(0,230,118,.2) }
.badge-warn { background:var(–warn-pale); color:var(–warn); border:1px solid rgba(255,171,0,.2) }
.badge-bad  { background:var(–danger-pale); color:var(–danger); border:1px solid rgba(255,82,82,.2) }

/* ══════════════════════════════════════
SENSOR GRID
══════════════════════════════════════ */
.sensor-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:4px }
.sensor-card {
background:var(–card); border:1px solid var(–border); border-radius:var(–r-xl); padding:16px;
position:relative; overflow:hidden; transition:border-color var(–ease), transform var(–ease);
}
.sensor-card:active { transform:scale(.97) }
.sc-accent-line { position:absolute; top:0; left:0; right:0; height:2px }
.sc-ph  .sc-accent-line { background:var(–accent) }
.sc-ec  .sc-accent-line { background:var(–blue) }
.sc-wt  .sc-accent-line { background:var(–warn) }
.sc-air .sc-accent-line { background:var(–violet) }
.sc-icon { font-size:20px; margin-bottom:8px; display:block }
.sc-label { font-family:var(–mono); font-size:9px; font-weight:700; color:var(–text-3); text-transform:uppercase; letter-spacing:.7px; margin-bottom:6px }
.sc-val { font-family:var(–mono); font-size:28px; font-weight:700; color:var(–text); line-height:1; display:flex; align-items:baseline; gap:3px; margin-bottom:10px }
.sc-unit { font-size:12px; font-weight:400; color:var(–text-3) }
.sc-trend { font-size:11px; font-weight:700; margin-left:2px }
.trend-up { color:var(–danger) }
.trend-down { color:var(–blue) }
.trend-flat { color:var(–text-3) }
.sc-bar-track { height:3px; background:var(–bg3); border-radius:2px; overflow:hidden; margin-bottom:8px }
.sc-bar-fill { height:100%; border-radius:2px; transition:width .9s cubic-bezier(.4,0,.2,1) }
.sc-badge { display:inline-flex; align-items:center; gap:4px; font-family:var(–mono); font-size:9px; font-weight:700; padding:3px 8px; border-radius:4px; text-transform:uppercase; letter-spacing:.4px }
.sc-air-row { display:flex; gap:0 }
.sc-air-col { flex:1 }
.sc-air-div { width:1px; background:var(–border); margin:0 10px }
.sc-air .sc-val { font-size:22px }

/* ══════════════════════════════════════
RELAY CARDS
══════════════════════════════════════ */
.relay-row { display:flex; gap:10px; margin-bottom:4px }
.relay-card {
flex:1; background:var(–card); border:1px solid var(–border);
border-radius:var(–r-xl); padding:16px;
transition:border-color var(–ease), transform var(–ease);
}
.relay-card:active { transform:scale(.97) }
.relay-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:12px }
.relay-icon { width:38px; height:38px; border-radius:var(–r-md); display:flex; align-items:center; justify-content:center; font-size:18px }
.ri-pump { background:var(–blue-pale); border:1px solid var(–blue-pale) }
.ri-fan  { background:var(–violet-pale); border:1px solid var(–violet-pale) }
.relay-name { font-family:var(–display); font-size:13px; font-weight:700; color:var(–text); margin-bottom:2px }
.relay-mode { font-family:var(–mono); font-size:9px; color:var(–text-3); letter-spacing:.3px }
.relay-status { display:inline-flex; align-items:center; gap:5px; margin-top:8px; font-family:var(–mono); font-size:10px; font-weight:700; padding:4px 9px; border-radius:4px }
.rs-on  { background:var(–accent-pale); color:var(–accent); border:1px solid rgba(0,230,118,.2) }
.rs-off { background:var(–bg3); color:var(–text-3); border:1px solid var(–border) }
.rs-dot { width:5px; height:5px; border-radius:50% }
.rs-on  .rs-dot { background:var(–accent); animation:pulseDot 2s infinite }
.rs-off .rs-dot { background:var(–text-3) }
.toggle { position:relative; width:44px; height:24px; cursor:pointer; flex-shrink:0 }
.toggle input { display:none }
.t-track { position:absolute; inset:0; background:var(–bg3); border-radius:12px; transition:background var(–ease); border:1.5px solid var(–border) }
.toggle input:checked ~ .t-track { background:var(–accent); border-color:transparent }
.t-thumb { position:absolute; left:3px; top:3px; width:18px; height:18px; background:#fff; border-radius:50%; box-shadow:0 2px 6px rgba(0,0,0,.25); transition:transform var(–ease) }
.toggle input:checked ~ .t-track ~ .t-thumb { transform:translateX(20px) }
.tl-wrap { display:flex; align-items:center; gap:6px }
.tl { font-family:var(–mono); font-size:11px; font-weight:700; min-width:24px; text-align:right }

/* ══════════════════════════════════════
QUICK ACTIONS
══════════════════════════════════════ */
.qa-scroll { display:flex; gap:8px; overflow-x:auto; padding-bottom:6px; margin-bottom:4px }
.qa-scroll::-webkit-scrollbar { display:none }
.qa-card {
flex-shrink:0; width:120px; border-radius:var(–r-lg); padding:14px 13px;
cursor:pointer; transition:transform var(–spring), box-shadow var(–ease);
display:flex; flex-direction:column; gap:8px; border:1px solid transparent; position:relative; overflow:hidden;
}
.qa-card:active { transform:scale(.94) }
.qa-green  { background:var(–accent); color:#0f1117 }
.qa-blue   { background:var(–blue-pale); color:var(–blue); border-color:rgba(68,138,255,.2) }
.qa-warn   { background:var(–warn-pale); color:var(–warn); border-color:rgba(255,171,0,.2) }
.qa-violet { background:var(–violet-pale); color:var(–violet); border-color:rgba(224,64,251,.2) }
